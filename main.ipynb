class SpamRNN(nn.Module):
    def __init__(self, vocab_size, embed_dim=100, hidden_dim=128, dropout=0.3):
        super().__init__()
        self.embedding = nn.Embedding(vocab_size, embed_dim, padding_idx=0)
        self.dropout = nn.Dropout(dropout)
        self.lstm = nn.LSTM(embed_dim, hidden_dim, batch_first=True, bidirectional=True, num_layers=2, dropout=dropout)
        self.fc = nn.Linear(hidden_dim * 2 + 1, 1)  # *2 for bidirectional
        self.sigmoid = nn.Sigmoid()

    def forward(self, x, msg_len):
        x = self.embedding(x)
        x = self.dropout(x)
        _, (hidden, _) = self.lstm(x)
        hidden = hidden[-1]
        combined = torch.cat([hidden, msg_len], dim=1)
        out = self.fc(combined)
        return self.sigmoid(out).squeeze()